{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "distribution": "internal",
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote"
      }
    },
    "production": {
      "android": {
        "distribution": "store",
        "buildType": "app-bundle",
        "credentialsSource": "local"
      },
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "chiefjustin98@icloud.com",
        "ascAppId": "FILL_IN_AFTER_CREATING_APP",
        "appleTeamId": "FILL_IN_FROM_APPLE_DEVELOPER"
      }
    }
  }
}
