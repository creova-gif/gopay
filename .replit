modules = ["nodejs-20", "python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Go (Tunnel)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Go (Tunnel)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd expo-app && npx expo start --tunnel"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8081
externalPort = 8081

[agent]
expertMode = true

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "build"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
